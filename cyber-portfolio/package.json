{
  "name": "cyber-portfolio",
  "private": true,
  "version": "0.1.0",
  "description": "Futuristic cyberpunk developer portfolio. Next.js (static export) + React Three Fiber + GSAP. Animated intro, GPU neon particles, an interactive 3D workspace, scroll-driven camera transitions, Lenis smooth scrolling, glassmorphism UI and bloom post-processing.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node -e \"require('fs').writeFileSync('out/.nojekyll','')\"",
    "preview": "npx --yes serve -l 5181 out",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d out -e cyber-portfolio -t"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "lenis": "^1.1.18",
    "lucide-react": "^0.454.0",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "three": "^0.169.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
