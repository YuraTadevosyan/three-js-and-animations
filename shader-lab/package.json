{
  "name": "shader-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GLSL shader experimentation lab built with React Three Fiber. Water, noise distortion, hologram, and GPU particle demos with real-time controls.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -e shader-lab"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
